# ---------------------------------------------------------------------------
# SaaSVoice environment variables
# Copy this file to `.env` and fill in values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# ===========================================================================
# LOCAL DEVELOPMENT (npm run dev)
# ===========================================================================

# Database (Postgres). The local dev Docker Compose maps Postgres to host 5433
# (to avoid clashing with any local Postgres already on 5432).
DATABASE_URL="postgresql://saasvoice:saasvoice@localhost:5433/saasvoice?schema=public"

# Auth.js / NextAuth v5. Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
AUTH_SECRET="change-me-to-a-long-random-string"
# Public URL of the app (used by NextAuth for callbacks).
NEXTAUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# AI provider
# AI_PROVIDER=mock   -> no API key required (default; great for local + first deploy)
# AI_PROVIDER=gemini -> requires GEMINI_API_KEY (Google AI Studio free tier)
# ---------------------------------------------------------------------------
AI_PROVIDER="mock"
GEMINI_API_KEY=""
# Optional: override the Gemini model. Defaults to a free-tier-friendly model.
GEMINI_MODEL="gemini-flash-latest"

# Usage limits (server-enforced). One generation RUN = 1 unit.
FREE_MONTHLY_GENERATIONS="30"

# ===========================================================================
# PRODUCTION (docker compose up -d)
# The production compose builds DATABASE_URL from these Postgres parts, so you
# do NOT need to set DATABASE_URL above when deploying with Docker Compose.
# ===========================================================================

POSTGRES_USER="saasvoice"
# Use a long random password in production: openssl rand -base64 24
POSTGRES_PASSWORD="change-me-strong-db-password"
POSTGRES_DB="saasvoice"

# Optional: only needed if you enable the Caddy TLS proxy
# (docker compose --profile proxy up -d). Point this domain's DNS at the VM.
DOMAIN_NAME="saasvoice.example.com"
